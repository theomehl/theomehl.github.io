<!DOCTYPE html>
<html lang="en" data-theme="system">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} | tedmehl.me</title>
    <meta name="description" content="{{description}}">
    <meta name="generator" content="{{ eleventy.generator }}">
    
    <link rel="preload" as="font" href="/fonts/Figtree.woff2" crossorigin>
    <link rel="preload" as="font" href="/fonts/Figtree-Italic.woff2" crossorigin>
    {% set css %}
        {% include "src/styles/index.css" %}
    {% endset %}
    <style>
        {{ css | cssmin | safe }}
    </style>
    {% if extraStyles %}
    <style>
        {{ extraStyles | cssmin | safe }}
    </style>
    {% endif %}
    <link rel="icon" href="/favicon.png">
    <script>
        let theme = localStorage.getItem('theme');
        if (theme) {
            document.documentElement.setAttribute('data-theme', theme);
        }
    </script>

</head>
<body>
    <a href="#main" class="skip-link">Skip to main content</a>
    <header class="container">
        <nav class="nav-list">
            <a href="/" class="header-logo-wrapper"><span class="first-initial">T</span><span class="second-initial">M</span></a>
            <ul>
                <li><a href="/blog/">blog</a></li>
                <li><a href="/notes/">notes</a></li>
                <li><a href="/commonplace/">commonplace book</a></li>
                <li><a href="https://photos.tedmehl.me">photos</a></li>
            </ul>
        </nav>
    </header>

    {{content | safe}}

    <footer class="container">
        <hr>
        <div class="footer-wrapper">
            <p class="copyright"><small>&copy; {% year %} </small></p>
            <div style="display: flex; gap: 0.5rem;">
                <p><small>Theme: </small></p>
                <button aria-pressed="true" value="system">System</button>
                <button aria-pressed="false" value="light">Light</button>
                <button aria-pressed="false" value="dark">Dark</button>
            </div>
            <nav class="nav-list secondary-nav">
                <ul>
                    <li><small><a href="/demos/">demos</a></small></li>
                    <li><small><a href="/feed.xml">rss feed</a></small></li>
                    <li><small><a href="/colophon/">colophon</a></small></li>

                </ul>
            </nav>
        </div>
    </footer>
    <script>
        if (navigator && navigator.serviceWorker) {
            navigator.serviceWorker.register('/sw.js');
        }

        function switchTheme(button) {
            document.querySelector('button[aria-pressed="true"]').setAttribute('aria-pressed', false);
            button.setAttribute('aria-pressed', true);
            document.documentElement.setAttribute('data-theme', button.value);
            localStorage.setItem('theme', button.value);
        }

        function setThemeButtons(theme) {
            if (document.querySelector('button[aria-pressed="true"]').value === theme) return;
            document.querySelector(`button[value="${theme}"]`).setAttribute('aria-pressed', true);
            document.querySelector('button[aria-pressed="true"]').setAttribute('aria-pressed', false);
        }

        document.addEventListener("click", function(event) {
            if (event.target.matches('button[aria-pressed]')) {
                switchTheme(event.target);
            }
        });

        setThemeButtons(theme);
    </script>
</body>
</html>